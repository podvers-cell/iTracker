# انسخ القيم إلى إعدادات المشروع على Vercel: Settings → Environment Variables
# ثم أعد نشر المشروع (Redeploy).

# Firebase (واجهة العميل + التحقق من التوكن في /api/ai)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# مطابقة UID المستخدم المسموح له باستدعاء المساعد الذكي (من Firebase Auth)
ADMIN_UID=

# مفتاح واحد على الأقل للمساعد (حسب ما تستخدم في الكود)
OPENAI_API_KEY=
# أو
# GEMINI_API_KEY=
# GEMINI_MODEL=
# أو
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=
# DEEPSEEK_MODEL=

# OpenAI (الافتراضي إن لم تستخدم Gemini/DeepSeek)
# OPENAI_MODEL=
