rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function ownsProject(projectId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/projects/$(projectId))
        && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerUid == request.auth.uid;
    }

    match /projects/{projectId} {
      allow read, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;
    }

    match /transactions/{transactionId} {
      allow read, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && ownsProject(request.resource.data.projectId);
    }

    match /customers/{customerId} {
      allow read, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
